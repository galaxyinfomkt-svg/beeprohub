essage</td><td style=\"padding:12px 0;color:#333;font-size:14px;line-height:1.6;\">{{ $('Format Data').item.json.message }}</td></tr>\n    </table>\n    <div style=\"margin-top:24px;text-align:center;\">\n      <a href=\"https://app.gohighlevel.com/\" style=\"display:inline-block;background:linear-gradient(135deg,#fec603,#e5b003);color:#141112;padding:12px 32px;border-radius:6px;text-decoration:none;font-weight:700;font-size:14px;\">View in GoHighLevel</a>\n    </div>\n  </div>\n  <div style=\"background:#141112;padding:20px 40px;text-align:center;border-radius:0 0 8px 8px;\">\n    <p style=\"color:rgba(255,255,255,0.5);font-size:11px;margin:0;\">Bee Pro Hub by Galaxy IT & Marketing | Marlborough, MA | (774) 285-2299</p>\n    <p style=\"color:rgba(255,255,255,0.3);font-size:10px;margin:6px 0 0;\">Automated notification from BeeProHub website</p>\n  </div>\n</div>",
